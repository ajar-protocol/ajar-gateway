# Ajar Gateway reverse-proxy and optional Ajar read-serving configuration.
#
# The Gateway fails closed: missing or invalid values prevent startup.
# Bodies larger than max_body_bytes are rejected before proxying when the
# request declares Content-Length, and streaming bodies are capped while sent
# upstream.

origin_url = "http://127.0.0.1:8080"
listen_addr = "0.0.0.0:8081"
admin_addr = "127.0.0.1:9090"

# Safe defaults are used when omitted.
request_timeout_ms = 30000
max_body_bytes = 10485760

# Optional. When omitted, the Gateway remains a pure reverse proxy and
# /.well-known/ajar.json passes through to the origin.
#
# When set, this directory must contain an already-signed prepared content
# store: manifest.json, view-index.json, and views/*.json.
# store_dir = "/var/lib/ajar-gateway/content-store"
